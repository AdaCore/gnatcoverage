with GPR2.Build.Actions.Instrument_Source;

with Instrument;
with Instrument.Common; use Instrument.Common;
with Switches;          use Switches;
with Strings;           use Strings;

package GPR2.Build.Actions.Thread.Instrument_Source is

   type Object is new GPR2.Build.Actions.Thread.Object with record
      Instrument_Object : GPR2.Build.Actions.Instrument_Source.Object_Acc;
   end record;

   procedure Initialize
     (Self         : in out Object;
      LU_Info      : Library_Unit_Info;
      IC           : Inst_Context_Acc;
      Instrumenter : Instrument.Common.Language_Instrumenter_Acc;
      Prj_Info     : Project_Info_Access;
      Dump_Config  : Any_Dump_Config);

   overriding
   procedure Compute_Signature
     (Self : in out Object; Check_Checksums : Boolean);
   --  Compute inputs and outputs for the given unit
   --  instrumentation action.
   --
   --  The inputs are the source file, its dependencies, and the files
   --  instrumented in the context of this unit instrumentation action.
   --
   --  The outputs are the instrumentation artifacts resulting from the
   --  source instrumentation command.

   overriding
   function On_Tree_Insertion
     (Self : Object; Db : in out GPR2.Build.Tree_Db.Object) return Boolean;
   --  The On_Tree_Insertion primitive enables the action to insert its input
   --  and output artifacts, or any follow up action in the database so that
   --  the process scheduler execute actions in the right order. As the source
   --  instrumentation process is streamlined (one action for every
   --  instrumented sources), there is no need to take care of this. Thus this
   --  function has a dummy implementation that returns True.

   overriding
   function Post_Execution
     (Self   : in out Object;
      Status : Execution_Status;
      Stdout : US.Unbounded_String := US.Null_Unbounded_String;
      Stderr : US.Unbounded_String := US.Null_Unbounded_String) return Boolean;
   --  Copy the SID file generated by the source instrumentation action to the
   --  library directory if needed.

   overriding
   function Extended (Self : Object) return Object
   is (raise Internal_Error with "This action is not extending");
   --  Do not handle project extension for now: always reinstrument even if
   --  the source was instrumented in an extended project.

   overriding
   function View (Self : Object) return GPR2.Project.View.Object;

   overriding
   function Working_Directory (Self : Object) return Path_Name.Object;

   overriding
   function UID (Self : Object) return Actions.Action_Id'Class
   is (Self.Instrument_Object.UID);

   overriding
   function Execute
     (Self   : in out Object;
      Stdout : in out US.Unbounded_String;
      Stderr : in out US.Unbounded_String) return Integer;
   --  Execute in thread the instrument source action

private
   overriding
   function View (Self : Object) return GPR2.Project.View.Object
   is (Self.Ctxt);

   overriding
   function Working_Directory (Self : Object) return Path_Name.Object
   is (Self.Ctxt.Object_Directory);

end GPR2.Build.Actions.Thread.Instrument_Source;
